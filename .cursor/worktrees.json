{
  "setup-worktree-unix": [
    "pnpm install",
    "[ -f \"$ROOT_WORKTREE_PATH/.env.local\" ] && cp \"$ROOT_WORKTREE_PATH/.env.local\" .env.local || true"
  ],
  "setup-worktree-windows": [
    "pnpm install",
    "if (Test-Path \"$env:ROOT_WORKTREE_PATH\\.env.local\") { Copy-Item \"$env:ROOT_WORKTREE_PATH\\.env.local\" .env.local }"
  ],
  "setup-worktree": [
    "pnpm install",
    "echo 'Copy .env.local from main worktree if present; on Unix use setup-worktree-unix.'"
  ]
}
